rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ChatSession validation
    function isValidChatSession(data) {
      return data.keys().hasAll(['id', 'title', 'model', 'createdAt', 'userId'])
        && (data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAll(['searchGrounding'])))
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.model is string && data.model.size() <= 100
        && data.createdAt is int
        && data.userId == request.auth.uid;
    }

    // Message validation
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'text', 'timestamp'])
        && (data.keys().size() == 4 || data.keys().size() == 5 || data.keys().size() == 6)
        && data.id is string && data.id.size() <= 128
        && (data.role == 'user' || data.role == 'assistant')
        && data.text is string && data.text.size() <= 65536
        && data.timestamp is int;
    }

    match /sessions/{sessionId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(sessionId) && isValidChatSession(incoming());
      allow update: if isSignedIn() && isValidId(sessionId) && isValidChatSession(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'model', 'searchGrounding'])
      );
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      match /messages/{messageId} {
        function isSessionOwner() {
          return get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        }

        allow get: if isSignedIn() && isSessionOwner();
        allow list: if isSignedIn() && isSessionOwner();
        
        allow create: if isSignedIn() && isValidId(messageId) && isSessionOwner() && isValidMessage(incoming());
        allow update: if isSignedIn() && isValidId(messageId) && isSessionOwner() && isValidMessage(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['text', 'groundingSources', 'attachments'])
        );
        allow delete: if isSignedIn() && isSessionOwner();
      }
    }
  }
}
